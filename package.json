{
  "name": "clumo",
  "version": "1.0.0",
  "private": true,
  "description": "AI-powered live call coaching for sales teams",
  "workspaces": [
    "server",
    "web",
    "electron"
  ],
  "scripts": {
    "dev:server": "npm run dev --workspace=server",
    "dev:web": "npm run dev --workspace=web",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:web\"",
    "build:web": "npm run build --workspace=web",
    "build:electron": "npm run build --workspace=electron",
    "start": "npm start --workspace=server",
    "test": "npm run test:unit && npm run test:e2e",
    "test:unit": "npm run test --workspace=server && npm run test --workspace=web",
    "test:server": "npm run test --workspace=server",
    "test:web": "npm run test --workspace=web",
    "test:coverage": "npm run test:coverage --workspace=server && npm run test:coverage --workspace=web",
    "test:e2e": "playwright test",
    "test:e2e:browser": "playwright test --project=browser",
    "test:e2e:electron": "playwright test --project=electron",
    "test:e2e:ui": "playwright test --ui"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "concurrently": "^9.1.2"
  }
}
